<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_shell_proxy_dialog"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="@string/web_home_extension_debug_title"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reload"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:minWidth="72dp"
            android:text="@string/web_home_extension_preview"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/tabGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabWeb"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="84dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_tab_web"
                android:textColor="@color/dialog_toggle_button_text"
                app:backgroundTint="@color/dialog_toggle_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabConsole"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="84dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_tab_console"
                android:textColor="@color/dialog_toggle_button_text"
                app:backgroundTint="@color/dialog_toggle_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabElements"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="84dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_tab_elements"
                android:textColor="@color/dialog_toggle_button_text"
                app:backgroundTint="@color/dialog_toggle_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabNetwork"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="84dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_tab_network"
                android:textColor="@color/dialog_toggle_button_text"
                app:backgroundTint="@color/dialog_toggle_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabCode"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="84dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_tab_code"
                android:textColor="@color/dialog_toggle_button_text"
                app:backgroundTint="@color/dialog_toggle_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/pages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/web"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/consoleLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.fongmi.android.tv.ui.custom.SafeScrollEditText
                android:id="@+id/consoleText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:scrollbars="none"
                android:singleLine="false"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/elementsLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.fongmi.android.tv.ui.custom.SafeScrollEditText
                android:id="@+id/elementsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:scrollbars="none"
                android:singleLine="false"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/networkLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/networkFilterGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/filterAll"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:text="@string/web_home_extension_network_all"
                        android:textColor="@color/dialog_toggle_button_text"
                        app:backgroundTint="@color/dialog_toggle_button_bg"
                        app:strokeColor="@color/dialog_outlined_button_stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/filterWeb"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:text="@string/web_home_extension_network_web"
                        android:textColor="@color/dialog_toggle_button_text"
                        app:backgroundTint="@color/dialog_toggle_button_bg"
                        app:strokeColor="@color/dialog_outlined_button_stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/filterScript"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:text="@string/web_home_extension_network_script"
                        android:textColor="@color/dialog_toggle_button_text"
                        app:backgroundTint="@color/dialog_toggle_button_bg"
                        app:strokeColor="@color/dialog_outlined_button_stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/filterError"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:text="@string/web_home_extension_network_error"
                        android:textColor="@color/dialog_toggle_button_text"
                        app:backgroundTint="@color/dialog_toggle_button_bg"
                        app:strokeColor="@color/dialog_outlined_button_stroke" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </HorizontalScrollView>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/web_home_extension_network_filter"
                app:boxBackgroundColor="@color/white"
                app:boxStrokeColor="@color/dialog_outlined_button_stroke"
                app:hintTextColor="#5F6368">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/networkSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:importantForAutofill="no"
                    android:inputType="textNoSuggestions|textUri"
                    android:scrollHorizontally="true"
                    android:scrollbars="none"
                    android:singleLine="true"
                    android:textColor="@color/black"
                    android:textColorHint="#666666" />

            </com.google.android.material.textfield.TextInputLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:background="#FAFAFA">

                <com.fongmi.android.tv.ui.custom.CustomNestedScrollView
                    android:id="@+id/networkRowsVertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <HorizontalScrollView
                        android:id="@+id/networkRowsHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fillViewport="true"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/networkRows"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="980dp"
                            android:orientation="vertical" />

                    </HorizontalScrollView>

                </com.fongmi.android.tv.ui.custom.CustomNestedScrollView>

            </FrameLayout>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/web_home_extension_network_detail"
                    android:textColor="#202124"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailSmaller"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="32dp"
                    android:minHeight="32dp"
                    android:minWidth="0dp"
                    android:contentDescription="@string/web_home_extension_network_detail_smaller"
                    android:text=""
                    android:textColor="@color/dialog_outlined_button_text"
                    app:icon="@drawable/ic_detail_minus"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconTint="@color/dialog_outlined_button_text"
                    app:backgroundTint="@color/dialog_outlined_button_bg"
                    app:strokeColor="@color/dialog_outlined_button_stroke" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailBigger"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:minHeight="32dp"
                    android:minWidth="0dp"
                    android:contentDescription="@string/web_home_extension_network_detail_bigger"
                    android:text=""
                    android:textColor="@color/dialog_outlined_button_text"
                    app:icon="@drawable/ic_detail_plus"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconTint="@color/dialog_outlined_button_text"
                    app:backgroundTint="@color/dialog_outlined_button_bg"
                    app:strokeColor="@color/dialog_outlined_button_stroke" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <FrameLayout
                android:id="@+id/networkDetailFrame"
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:background="#FAFAFA">

                <com.fongmi.android.tv.ui.custom.SafeScrollEditText
                    android:id="@+id/networkDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:fontFamily="monospace"
                    android:gravity="start|top"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:padding="8dp"
                    android:scrollHorizontally="true"
                    android:scrollbars="none"
                    android:singleLine="false"
                    android:textColor="@color/black"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

            </FrameLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/codeLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.fongmi.android.tv.ui.custom.SafeScrollEditText
                android:id="@+id/codeText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:hint="@string/web_home_extension_code_hint"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:scrollbars="none"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textColorHint="#666666" />

        </com.google.android.material.textfield.TextInputLayout>

    </FrameLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inspect"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="92dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_inspect_element"
                android:textColor="@color/dialog_tonal_button_text"
                app:backgroundTint="@color/dialog_tonal_button_bg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/refreshConsole"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="92dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_refresh_console"
                android:textColor="@color/dialog_tonal_button_text"
                app:backgroundTint="@color/dialog_tonal_button_bg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="108dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/web_home_extension_save_preview"
                android:textColor="@color/dialog_primary_button_text"
                app:backgroundTint="@color/dialog_primary_button_bg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/close"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="92dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:text="@string/dialog_negative"
                android:textColor="@color/dialog_outlined_button_text"
                app:backgroundTint="@color/dialog_outlined_button_bg"
                app:strokeColor="@color/dialog_outlined_button_stroke" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </HorizontalScrollView>

</androidx.appcompat.widget.LinearLayoutCompat>
